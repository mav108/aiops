AIOPS_ENVIRONMENT=local
AIOPS_STATE_FILE=.data/aiops-state.json
AIOPS_EXECUTION_MODE=mock
AIOPS_REMEDIATION_ALLOWLIST=restart_vm,resize_vmss,run_automation_webhook,adjust_autoscale_rule,create_ticket,manual_action_required
AIOPS_DESTRUCTIVE_ACTION_ALLOWLIST=
AIOPS_AZURE_SUBSCRIPTION_IDS=
AIOPS_LOG_ANALYTICS_WORKSPACE_ID=
AIOPS_LOG_ANALYTICS_WORKSPACE_MAP=
AIOPS_LOG_QUERY_TIMESPAN_MINUTES=60
AIOPS_ENABLE_LIVE_AZURE_INTEGRATIONS=false
AIOPS_AUTOMATION_WEBHOOK_URL=
AIOPS_AUTH_ENABLED=false
AIOPS_AUTH_TENANT_ID=organizations
AIOPS_AUTH_CLIENT_ID=
AIOPS_AUTH_CLIENT_SECRET=
AIOPS_AUTH_SESSION_SECRET=change-me-to-a-long-random-secret
AIOPS_AUTH_SCOPES=openid profile email
AIOPS_AUTH_POST_LOGOUT_REDIRECT_URI=http://127.0.0.1:8000/
AIOPS_AZURE_OPENAI_ENDPOINT=
AIOPS_AZURE_OPENAI_DEPLOYMENT=
AIOPS_AZURE_OPENAI_API_VERSION=v1
AIOPS_AZURE_OPENAI_API_KEY=
AIOPS_AZURE_OPENAI_AUTH_MODE=api_key
